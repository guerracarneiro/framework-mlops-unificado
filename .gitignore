# =========================================================
# DADOS
# Mantém estrutura com .gitkeep, mas ignora conteúdo real
# =========================================================
data/raw/**
data/processed/**

!data/raw/.gitkeep
!data/processed/.gitkeep
!data/raw/clones/.gitkeep
!data/processed/clones/.gitkeep

# =========================================================
# MODELOS E ARQUIVOS GERADOS
# =========================================================
models/*
!models/.gitkeep

*.pkl
*.joblib
*.parquet

reports/*.csv
reports/*.xlsx
reports/*.parquet
reports/*.json

