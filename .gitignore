# =========================================================
# PYTHON
# =========================================================
**/__pycache__/
*.py[cod]
*$py.class

# =========================================================
# AMBIENTE / IDE
# =========================================================
.venv/
venv/
.env
.python-version
.vscode/
.idea/

# =========================================================
# JUPYTER
# =========================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# =========================================================
# MLFLOW
# =========================================================
mlruns/
mlflow.db

# =========================================================
# ARTEFATOS DE EXECUÇÃO
# Mantém conteúdo real fora do Git, mas permite arquivos .dvc
# =========================================================
artifacts/**
!artifacts/
!artifacts/**/
!artifacts/**/*.dvc
!artifacts/**/.gitkeep

# =========================================================
# DADOS
# Mantém conteúdo real fora do Git, mas permite arquivos .dvc
# e arquivos .gitkeep em qualquer subpasta
# =========================================================
data/raw/**
data/processed/**

!data/raw/
!data/raw/**/
!data/raw/**/*.dvc
!data/raw/**/.gitkeep

!data/processed/
!data/processed/**/
!data/processed/**/*.dvc
!data/processed/**/.gitkeep

# =========================================================
# MODELOS E ARQUIVOS GERADOS
# Mantém estrutura, mas não versiona modelos/exportações
# =========================================================
models/**
!models/
!models/**/
!models/**/.gitkeep

*.pkl
*.joblib
*.parquet
*.h5
*.keras

reports/*.csv
reports/*.xlsx
reports/*.parquet
reports/*.json

# =========================================================
# DVC
# =========================================================
.dvc/tmp/
.dvc/cache/

# =========================================================
# LOGS E TEMPORÁRIOS
# =========================================================
*.log
*.tmp
*.bak

# =========================================================
# SISTEMA OPERACIONAL
# =========================================================
.DS_Store
Thumbs.db
desktop.ini
_handoff_chat/